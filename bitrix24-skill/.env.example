export B24_DOMAIN="your-portal.example"
export B24_AUTH_MODE="webhook"

# Webhook mode
export B24_WEBHOOK_USER_ID="1"
export B24_WEBHOOK_CODE="your_webhook_secret_without_user_id_prefix"

# OAuth mode (optional)
# export B24_ACCESS_TOKEN=""
# export B24_REFRESH_TOKEN=""
# export B24_CLIENT_ID=""
# export B24_CLIENT_SECRET=""

# Optional quality/safety controls
# export B24_PACKS="core"
# CAUTION: the allowlist below is a BROAD example (grants wide CRM/task/event write access).
# Narrow it to the methods you actually use; prefer --packs for least privilege.
# export B24_METHOD_ALLOWLIST="batch,user.*,department.*,crm.*,tasks.task.*,task.*,event.*"
# export B24_AUDIT_FILE=".runtime/b24_audit.jsonl"
# export B24_REQUIRE_PLAN="1"
# export B24_PLAN_FILE=".runtime/bitrix24_plans.json"
# export B24_PLAN_TTL_SEC="1800"
# export B24_IDEMPOTENCY_FILE=".runtime/bitrix24_idempotency.json"
# export B24_IDEMPOTENCY_TTL_SEC="86400"
# export B24_RATE_LIMITER="file"
# export B24_RATE_LIMITER_FILE=".runtime/bitrix24_rate_limiter.json"
# Drain rate per second. Bitrix24 leaky-bucket: 2/s on standard plans, 5/s on Enterprise.
# export B24_RATE_LIMITER_RATE="2.0"
# Bucket size. Server block thresholds are 50 (standard) / 250 (Enterprise); the default
# 10 stays below that for headroom. Raise toward the server threshold for high throughput.
# export B24_RATE_LIMITER_BURST="10"
